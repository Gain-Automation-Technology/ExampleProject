<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="UN_Machine" Id="{21e30d72-cc39-422e-8114-15c7abc2b847}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK UN_Machine EXTENDS FB_UN_PackML_Base
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	// HMI
	s_stHmi : ST_UN_Machine_Hmi; // HMI structure (status and manual controls).
	
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// Call Super
// Basemodule calls the following base method by calling SUPER^(): 
// - m_Main
// Add module-specific cyclic logic before/after SUPER^() if required.

SUPER^();
]]></ST>
    </Implementation>
    <Folder Name="Basic" Id="{e89104c0-d33f-460a-aaf2-8953cfda25ab}" />
    <Folder Name="PackML States" Id="{1d885303-f3d2-4f24-8e9c-f2289cd3da1a}" />
    <Method Name="_m_Aborted" Id="{f71833b4-00b3-4f3f-b694-481d92187cf9}" FolderPath="PackML States\">
      <Declaration><![CDATA[METHOD PROTECTED _m_Aborted : BOOL (* Return state complete when state is ready*)
VAR_INPUT
	(*First cycle of this state*)
	i_bCmdRestart	: BOOL;
	i_eActMode	: GSBF_Common.E_PackML_Mode;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Allow clear when alarms are below critical.
// Add extra abort handling here if required.
IF s_fbAlarmCollector.p_eAlarmState < E_Alarm_Severity.Critical THEN
	s_fbPackML.m_ReqClear(); // Request clear of PackML state.
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="_m_Alarms" Id="{8fa8464a-636c-46ee-9f13-6e7927953bcd}" FolderPath="Basic\">
      <Declaration><![CDATA[METHOD PROTECTED _m_Alarms
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Call base alarm handling.
SUPER^._m_Alarms();

// Add unit-level alarm conditions here if needed.
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_m_Hmi" Id="{e2052703-323d-40e8-9f21-012122f38ffa}" FolderPath="Basic\">
      <Declaration><![CDATA[METHOD PROTECTED _m_Hmi
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Call base HMI handling.
SUPER^._m_Hmi();

// Expose alarm collector to HMI for diagnostics.
s_stHmi.fbHmiAlarmCollector(i_itfAlarmCollector := s_fbAlarmCollector);
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_m_Logic" Id="{b95711e4-a3f3-4e91-9f55-7c0e3689d897}" FolderPath="Basic\">
      <Declaration><![CDATA[METHOD PROTECTED _m_Logic]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Call base logic.
SUPER^._m_Logic();

// Unit-specific logic goes here (coordination between modules).
// Call HMI handling as part of the logic cycle.
_m_Hmi();]]></ST>
      </Implementation>
    </Method>
    <Method Name="_m_Modules" Id="{c15e282d-b76d-440b-8236-902bb4c31743}" FolderPath="Basic\">
      <Declaration><![CDATA[METHOD PROTECTED _m_Modules
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Call base module handling.
SUPER^._m_Modules();

// Call infeed conveyor module and link to lift handshake.
GVL_Modules.g_emInfeedConveyor(
	i_bReqEnable					:= TRUE, // Enable module (replace with safety chain if needed).
	i_bReqReset						:= s_fbAlarmCollector.q_bReqReset, // Reset from alarm collector.
	i_bStaSafetyOk					:= TRUE, // Safety chain OK (replace with real input).
	i_bReqSimulation				:= p_bStaSimulation, // Simulation flag from unit.
	i_itfPackML_Parent				:= s_fbPackML, // PackML parent interface.
	i_itfAlarmCollector_Parent		:= s_fbAlarmCollector, // Alarm collector parent.
	q_stStaPackML					=> , // Optional PackML status feedback.
	i_stFromLift					:= GVL_Modules.g_emLift.q_stFromLift); // Lift status to infeed.

// Call lift module and link to infeed handshake.
GVL_Modules.g_emLift(
	i_bReqEnable:= TRUE, // Enable module (replace with safety chain if needed).
	i_bReqReset:= s_fbAlarmCollector.q_bReqReset, // Reset from alarm collector.
	i_bStaSafetyOk:= TRUE, // Safety chain OK (replace with real input).
	i_bReqSimulation:= p_bStaSimulation, // Simulation flag from unit.
	i_itfPackML_Parent:= s_fbPackML, // PackML parent interface.
	i_itfAlarmCollector_Parent:= s_fbAlarmCollector, // Alarm collector parent.
	q_stStaPackML=> , // Optional PackML status feedback.
	i_stToLift:= GVL_Modules.g_emInfeedConveyor.q_stToLift, // Infeed commands to lift.
	q_stFromLift=> ); // Lift status output.
]]></ST>
      </Implementation>
    </Method>
    <Method Name="_m_Stopped" Id="{05f03b2a-7abf-40a2-b03f-2927d90e9758}" FolderPath="PackML States\">
      <Declaration><![CDATA[METHOD PROTECTED _m_Stopped : BOOL (* Return state complete when state is ready*)
VAR_INPUT
	(*First cycle of this state*)
	i_bCmdRestart	: BOOL;
	i_eActMode	: GSBF_Common.E_PackML_Mode;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Allow reset when alarms are below error level.
// Add extra stopped-state logic here if required.
IF s_fbAlarmCollector.p_eAlarmState < E_Alarm_Severity.Error THEN
	s_fbPackML.m_ReqReset(); // Request PackML reset.
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="m_Main" Id="{5738c138-41a1-473c-badd-a5f9691bbc49}">
      <Declaration><![CDATA[METHOD PUBLIC m_Main
VAR_INST
	s_fbAlarmToPackMl : FB_AlarmToPackML;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Main entry point for the unit.
// Use this to wrap additional high-level logic around base behavior.
SUPER^.m_Main();


s_fbAlarmToPackMl(i_eAlarmState:= p_itfAlarmCollector.p_eAlarmState, i_itfPackML_Command:= s_fbPackML);]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>