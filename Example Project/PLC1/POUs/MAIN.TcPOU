<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="MAIN" Id="{d8cf606a-bd90-4fc1-9637-3e8daf03509a}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM MAIN 
VAR
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
// Main program cycle: call top-level managers and units in a clear order.
// Keep this list small; detailed behavior belongs inside the modules.

// PackML status manager
// Collects and aggregates PackML status for the system.
GVL_Modules.g_fbPackMLstatusManager();
	
// Machine controls manager
// HMI manager translates user actions into machine control requests.
GVL_Modules.g_fbHmiMachCtrlsManager(
	i_itfMachineControl := GVL_Modules.g_fbMachCtrlsManager); // Link HMI to machine controls.
// Machine controls manager coordinates PackML state requests for the unit.
GVL_Modules.g_fbMachCtrlsManager(
	i_itfModule := GVL_Modules.g_unMachine); // Link controls to the unit interface.
	
// Units
// Call each unit FB with system-level flags and managers.
GVL_Modules.g_unMachine(
	i_bReqEnable				:= TRUE, // Master enable for the unit (replace with safety chain if needed).
	i_bReqReset					:= GVL_Modules.g_fbMachCtrlsManager.p_bReset, // Reset request from machine controls.
	i_bReqSimulation			:= TRUE, // Simulation mode flag (toggle for real hardware).
	i_itfPackML_Parent			:= GVL_Modules.g_fbPackMLstatusManager, // PackML status manager.
	i_itfAlarmCollector_Parent	:= ); // Optional alarm manager interface.
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>