<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.13">
  <POU Name="EM_Lift" Id="{06a5218e-af25-4987-9907-69e34a47bd46}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK EM_Lift EXTENDS FB_EM_PackML_Base
VAR_INPUT
	i_stToLift : ST_CommInfeedToLift; // Command from infeed to lift.
END_VAR
VAR_OUTPUT
	q_stFromLift : ST_CommLiftToInfeed; // Status from lift to infeed.
END_VAR
VAR
	// Variables
	s_stHmi : ST_EM_Lift_Hmi;	// HMI status and controls.


	// Control modules
	s_cmMotorLift : CM_ServoAX8000;	// Lift servo axis control.
	
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// Call Super
// Basemodule calls the following base method by calling SUPER^(): 
// - m_Main
// Add module-specific cyclic logic before/after SUPER^() if required.

SUPER^();]]></ST>
    </Implementation>
    <Folder Name="Basic" Id="{3cd35c1f-e6b6-4e74-8a75-44f6df3167e6}" />
    <Folder Name="PackML States" Id="{4f36ecdd-1a19-4667-86f8-991797151aab}" />
    <Folder Name="Sequencers" Id="{3b18b39a-8ba8-4403-b761-416bd7643d04}" />
    <Method Name="_m_Aborting" Id="{9d005501-a08d-43f6-9773-498185ae6b04}" FolderPath="PackML States\">
      <Declaration><![CDATA[METHOD PROTECTED _m_Aborting : BOOL // Return state complete when state is ready
VAR_INPUT
	i_bCmdRestart	: BOOL;	//First cycle of this state
	i_eActMode 		: E_PackML_Mode;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Abort and disable servo
// Use stop-sequence to bring the lift axis to a safe state.
// Add any extra abort actions here (e.g., vent valves, set outputs).
_m_Aborting	:= _m_SeqStopServos(i_bCmdRestart := i_bCmdRestart).p_bStaReady;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_m_Alarms" Id="{20b2fc11-1d6a-4bf9-b31a-4f2b7c96624c}" FolderPath="Basic\">
      <Declaration><![CDATA[(* Collect alarm conditions from sub-modules. *)
METHOD PROTECTED _m_Alarms
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(* All module alarms are handled in this method *)
(*==========================================================================================================*)
// Call base
SUPER^._m_Alarms();

// Add module-specific alarm conditions here and link them to the alarm collector.

]]></ST>
      </Implementation>
    </Method>
    <Method Name="_m_Execute" Id="{92f46940-158e-40ce-bda4-70a5dc66dd09}" FolderPath="PackML States\">
      <Declaration><![CDATA[METHOD PROTECTED _m_Execute : BOOL // Return state complete when state is ready
VAR_INPUT
	i_bCmdRestart	: BOOL;	//First cycle of this state
	i_eActMode 		: E_PackML_Mode;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Execute production sequence only in Production mode.
// For other modes, return TRUE or add mode-specific logic.
IF i_eActMode = E_PackML_Mode.Production THEN
	_m_Execute := _m_ProductionExecute(i_bCmdRestart := i_bCmdRestart).p_bStaReady;
ELSE
	_m_Execute := TRUE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="_m_Hmi" Id="{53ff0c5b-f318-4827-8d92-c4c6d3db8fb5}" FolderPath="Basic\">
      <Declaration><![CDATA[METHOD PROTECTED _m_Hmi
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Expose lift servo controls to the HMI in Manual mode.
// Extend this method with extra HMI widgets or status fields as needed.
s_stHmi.fbMotorLift(
	i_bReqEnableHmiControls:= s_fbPackML.p_eActMode = E_PackML_Mode.Manual, 
	i_itfCM_Servo:= s_cmMotorLift,
	i_eCfgMoveAbs:= E_HMI_CM_SERVO_MoveAbsMode_Direction.MoveToModuloPosShortestWay);]]></ST>
      </Implementation>
    </Method>
