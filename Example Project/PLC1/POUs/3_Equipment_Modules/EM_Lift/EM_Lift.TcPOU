// Initialize module-specific parameters and defaults here.

]]></ST>
      </Implementation>
    </Method>
    <Method Name="_m_Inputs" Id="{a8fd097b-120b-43a0-aeec-30d30a0ff4b0}" FolderPath="Basic\">
