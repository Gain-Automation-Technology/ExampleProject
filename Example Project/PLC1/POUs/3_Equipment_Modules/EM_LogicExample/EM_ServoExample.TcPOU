s_AlmFailure1.p_itfConfig.p_tmCfgDelay		:= T#1S;
s_AlmFailure1.p_itfConfig.p_eCfgSeverity	:= E_Alarm_Severity.Error;
s_AlmFailure1.p_itfConfig.p_stCfgEventEntry	:= TC_EVENTS.Alarmen.Alarm_1;
