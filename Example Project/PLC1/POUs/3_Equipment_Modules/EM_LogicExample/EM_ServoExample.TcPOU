    <Method Name="_m_Modules" Id="{69768295-7443-40c1-8644-57ec9b3eff02}" FolderPath="Basic\">
      <Declaration><![CDATA[METHOD PROTECTED _m_Modules]]></Declaration>
      <Implementation>
        <ST><![CDATA[SUPER^._m_Modules();

s_bAlwManualControl	:= s_fbPackML.p_eActMode = E_PackML_Mode.Manual 
					AND s_fbPackML.p_eActState = E_PackML_State.Execute;

s_cmVirtualMaster(
	i_bReqEnable				:= s_bStaEnable, 
	i_bReqReset					:= s_fbAlarmCollector.q_bReqReset, 
	i_bAlwManualCtrl			:= s_bAlwManualControl, 
	i_bReqSimulation			:= s_fbSimulation.q_bStaOn, 
	i_itfAlarmCollector_Parent	:= s_fbAlarmCollector, 
	i_bEmrStopOk				:= TRUE, 
	i_fOverride					:= 100.0, 
	i_bDisableForward			:= FALSE, 
	i_bDisableReverse			:= FALSE, 
	i_bDisableAxis				:= FALSE, 
	i_bExtReferenceSignal		:= FALSE
);

s_cmAxis1(
	i_bReqEnable				:= s_bStaEnable, 
	i_bReqReset					:= s_fbAlarmCollector.q_bReqReset, 
	i_bAlwManualCtrl			:= s_bAlwManualControl, 
	i_bReqSimulation			:= s_fbSimulation.q_bStaOn, 
	i_itfAlarmCollector_Parent	:= s_fbAlarmCollector, 
	i_bEmrStopOk				:= TRUE, 
	i_fOverride					:= 100.0, 
	i_bDisableForward			:= FALSE, 
	i_bDisableReverse			:= FALSE, 
	i_bDisableAxis				:= FALSE, 
	i_bExtReferenceSignal		:= FALSE
);
]]></ST>
      </Implementation>
    </Method>
