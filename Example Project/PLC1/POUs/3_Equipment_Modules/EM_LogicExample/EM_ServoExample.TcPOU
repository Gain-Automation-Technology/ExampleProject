    <Method Name="_m_Starting" Id="{74bc4b2f-043a-4038-b439-df9753c56557}" FolderPath="OMAC PackML\">
      <Declaration><![CDATA[METHOD PROTECTED _m_Starting : BOOL (* Return state complete when state is ready*)
VAR_INPUT
	(*First cycle of this state*)
	i_bCmdRestart	: BOOL;
	i_eActMode		: GBL.E_PackML_Mode;
END_VAR
VAR_INST
	s_eActMode					: E_PackML_Mode;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Execute only when in a specific mode
s_eActMode := i_eActMode;
CASE s_eActMode OF
	E_PackML_Mode.Production: 
		// Execute only when in PRODUCTION mode
		_m_Starting := _m_Starting_Production(i_bReqStart := i_bCmdRestart).p_bStaReady;
				
ELSE
	// Execute in all other modes	
	_m_Starting := TRUE;
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="_m_Starting_Production" Id="{400f85a2-e7d2-4436-aa22-f0a326fd6012}" FolderPath="OMAC PackML\">
      <Declaration><![CDATA[METHOD PROTECTED _m_Starting_Production : ITF_FB_SeqControl
VAR_INPUT
	i_bReqStart					: BOOL;
END_VAR
VAR_INST
	s_fbSeqControl				: FB_SeqControl;
	s_eSeq						: E_EM_LogicExample1_Seq_StartingProduction;
	s_eActMode					: E_PackML_Mode;
	s_stHomingOptions			: ST_HomingOptions;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Execute only when in a specific mode
s_eActMode := s_fbPackML.p_eActMode;

s_fbSeqControl(
	i_bReqStart		:= i_bReqStart, 
	i_rnActSeqStep	:= s_eSeq,
	i_sActSeqStep	:= TO_STRING(s_eSeq));

	
CASE s_eSeq OF
	E_EM_LogicExample1_Seq_StartingProduction.Idle:
		;

		
	E_EM_LogicExample1_Seq_StartingProduction.Start:	
		//Enable both axes in one singe sequencer step
		IF s_cmVirtualMaster.m_PowerOn()
			AND s_cmAxis1.m_PowerOn()
		THEN
			s_fbSeqControl.m_ReqStep(E_EM_LogicExample1_Seq_StartingProduction.ReferenceAxes);
		END_IF
		
		
	E_EM_LogicExample1_Seq_StartingProduction.ReferenceAxes:	
		//Reference when needed both axes in one singe sequencer step
		//Both methode give a TRUE when the axis is referenced
		//i_bForceReference := TRUE => The reference routine is allways started even when the axis is allready referenced
		//i_bForceReference := FALSE => The refference routine is only started when the axis is not already referenced
		//Recommended is to reference virtual axis allways and real axis only when they has loses the reference state		
		IF s_cmVirtualMaster.m_Home(
			i_bCmdExecute			:= s_fbSeqControl.p_bStaEntry,
			i_bForceReference		:= TRUE,
			i_eHomingMode			:= MC_HomingMode.MC_DefaultHoming,
			i_eBufferMode			:= MC_BufferMode.MC_Aborting,
			i_fPosition				:= 0.0,
			i_stOptions				:= s_stHomingOptions
		)
		AND s_cmAxis1.m_Home(
			i_bCmdExecute			:= s_fbSeqControl.p_bStaEntry,
			i_bForceReference		:= TRUE,
			i_eHomingMode			:= MC_HomingMode.MC_DefaultHoming,
			i_eBufferMode			:= MC_BufferMode.MC_Aborting,
			i_fPosition				:= 0.0,
			i_stOptions				:= s_stHomingOptions
		)
		THEN
			s_fbSeqControl.m_ReqStep(E_EM_LogicExample1_Seq_StartingProduction.Ready);
		END_IF
		
	E_EM_LogicExample1_Seq_StartingProduction.Ready:
		;
		
		
	E_EM_LogicExample1_Seq_StartingProduction.Error:
		;

END_CASE

_m_Starting_Production := s_fbSeqControl.m_getResult(TO_STRING(s_eSeq));
]]></ST>
      </Implementation>
    </Method>
