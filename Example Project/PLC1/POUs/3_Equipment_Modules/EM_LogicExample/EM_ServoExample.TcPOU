    <Method Name="_m_Stopping" Id="{f87d548b-0cad-4916-8130-e1f7b762eb18}" FolderPath="OMAC PackML\">
      <Declaration><![CDATA[METHOD PROTECTED _m_Stopping : BOOL (* Return state complete when state is ready*)
VAR_INPUT
	(*First cycle of this state*)
	i_bCmdRestart	: BOOL;
	i_eActMode		: GBL.E_PackML_Mode;
END_VAR
VAR_INST
	s_ITFExecutState 	: ITF_FB_SeqControl;
	s_eActMode			: E_PackML_Mode;
	s_ITFStopState		: ITF_FB_SeqControl;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Finish Execute only when in a specific mode
s_eActMode := i_eActMode;
CASE s_eActMode OF
	E_PackML_Mode.Production: 
		// Execute only when in PRODUCTION mode
		s_ITFExecutState := _m_Execute_Production(i_bReqStart := FALSE);
		//Stop axes in all modes
		s_ITFStopState := _m_StopServos(i_bReqStart := s_ITFExecutState.p_bStaReady);
		_m_Stopping := s_ITFStopState.p_bStaReady OR s_ITFStopState.p_bStaError;
ELSE
	s_ITFStopState := _m_StopServos(i_bReqStart := i_bCmdRestart);
	_m_Stopping := s_ITFStopState.p_bStaReady OR s_ITFStopState.p_bStaError;
END_CASE

]]></ST>
      </Implementation>
    </Method>
    <Method Name="_m_StopServos" Id="{5b343d6e-2672-4004-945d-26825f09df86}">
      <Declaration><![CDATA[METHOD PRIVATE _m_StopServos : ITF_FB_SeqControl
VAR_INPUT
	i_bReqStart				: BOOL;			// Reset sequencer
END_VAR
VAR_INST
	s_fbSeqControl			: FB_SeqControl;
	s_eSeq					: E_EM_LogicExample1_Seq_StopServos;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[s_fbSeqControl(
	i_bReqStart		:= i_bReqStart, 
	i_rnActSeqStep	:= s_eSeq,
	i_sActSeqStep	:= TO_STRING(s_eSeq));
	
CASE s_eSeq OF
	
	E_EM_LogicExample1_Seq_StopServos.Idle:
		;
		
	E_EM_LogicExample1_Seq_StopServos.Start:
		IF s_cmVirtualMaster.m_Stop(
			i_bCmdExecute		:= s_fbSeqControl.p_bStaEntry,
			i_fDeceleration		:= 0,
			i_fJerk				:= 0) 
		AND
			s_cmAxis1.m_Stop(
				i_bCmdExecute		:= s_fbSeqControl.p_bStaEntry,
				i_fDeceleration		:= 0,
				i_fJerk				:= 0) 
		THEN
			s_fbSeqControl.m_ReqStep(E_EM_LogicExample1_Seq_StopServos.Busy);
		END_IF
		
		//Add a time-out to be sure axis is disabled on time
		IF s_fbSeqControl.p_tmStepTime > T#100MS THEN
			s_fbSeqControl.m_ReqStep(E_EM_LogicExample1_Seq_StopServos.Busy);
		END_IF
		
	E_EM_LogicExample1_Seq_StopServos.Busy:	
		//Wait till axis is stopped. A time-out is added to sure that the axis is always disabled in on time		
		IF (s_cmVirtualMaster.p_rstAxisStatus.StandStill 
			AND s_cmAxis1.p_rstAxisStatus.StandStill) 
			OR s_fbSeqControl.p_tmStepTime > T#500MS 
		THEN
			s_cmVirtualMaster.m_PowerOff();
			s_cmAxis1.m_PowerOff();
			s_fbSeqControl.m_ReqStep(E_EM_LogicExample1_Seq_StopServos.Ready);
		END_IF
	
	E_EM_LogicExample1_Seq_StopServos.Ready:
		;

	E_EM_LogicExample1_Seq_StopServos.Error:
		;	

END_CASE

_m_StopServos := s_fbSeqControl.m_getResult(TO_STRING(s_eSeq));
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>